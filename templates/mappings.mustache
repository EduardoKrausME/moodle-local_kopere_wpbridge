{{!
    @template local_kopere_wpbridge/mappings

    Example context (json):
    {
        "title": "Mappings",
        "addurl": "http://example.com/local/kopere_wpbridge/editmapping.php",
        "backurl": "http://example.com/local/kopere_wpbridge/"
    }
}}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">{{title}}</h3>
    <div class="d-flex gap-2">
        <a href="{{{addurl}}}" class="btn btn-primary">{{#str}}mapping_add, local_kopere_wpbridge{{/str}}</a>
        <a href="{{{backurl}}}" class="btn btn-outline-secondary">{{#str}}back, local_kopere_wpbridge{{/str}}</a>
    </div>
</div>